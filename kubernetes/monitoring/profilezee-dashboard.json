{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "ProfileZee Microservices Observability Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "📊 HTTP Traffic",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"profilezee.*\", handler!=\"/health\", handler!=\"/metrics\"}[5m])) by (job)",
          "legendFormat": "{{job}}",
          "refId": "A"
        }
      ],
      "title": "HTTP Request Rate (req/s) per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "percentunit",
          "max": 1,
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{job=~\"profilezee.*\", status_code=~\"5..\"}[5m])) by (job) / sum(rate(http_requests_total{job=~\"profilezee.*\"}[5m])) by (job)",
          "legendFormat": "{{job}} 5xx rate",
          "refId": "A"
        },
        {
          "expr": "sum(rate(http_requests_total{job=~\"profilezee.*\", status_code=~\"4..\"}[5m])) by (job) / sum(rate(http_requests_total{job=~\"profilezee.*\"}[5m])) by (job)",
          "legendFormat": "{{job}} 4xx rate",
          "refId": "B"
        }
      ],
      "title": "Error Rate (4xx / 5xx) per Service",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 9 },
      "id": 3,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"profilezee.*\", handler!=\"/health\", handler!=\"/metrics\"}[5m])) by (job, le))",
          "legendFormat": "{{job}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"profilezee.*\", handler!=\"/health\", handler!=\"/metrics\"}[5m])) by (job, le))",
          "legendFormat": "{{job}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"profilezee.*\", handler!=\"/health\", handler!=\"/metrics\"}[5m])) by (job, le))",
          "legendFormat": "{{job}} p99",
          "refId": "C"
        }
      ],
      "title": "Request Latency p50 / p95 / p99 (FastAPI Services)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 9 },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_requests_seconds_bucket{job=\"profilezee-auth-service\"}[5m])) by (uri, le))",
          "legendFormat": "{{uri}} p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{job=\"profilezee-auth-service\"}[5m])) by (uri, le))",
          "legendFormat": "{{uri}} p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{job=\"profilezee-auth-service\"}[5m])) by (uri, le))",
          "legendFormat": "{{uri}} p99",
          "refId": "C"
        }
      ],
      "title": "Auth Service Latency p50 / p95 / p99 (Spring Boot)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 17 },
      "id": 101,
      "title": "☕ JVM — Auth Service (Spring Boot)",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 18 },
      "id": 5,
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"profilezee-auth-service\", area=\"heap\"}",
          "legendFormat": "Heap Used — {{id}}",
          "refId": "A"
        },
        {
          "expr": "jvm_memory_committed_bytes{job=\"profilezee-auth-service\", area=\"heap\"}",
          "legendFormat": "Heap Committed — {{id}}",
          "refId": "B"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"profilezee-auth-service\", area=\"heap\"}",
          "legendFormat": "Heap Max — {{id}}",
          "refId": "C"
        }
      ],
      "title": "JVM Heap Memory (Used / Committed / Max)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "bytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 18 },
      "id": 6,
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"profilezee-auth-service\", area=\"nonheap\"}",
          "legendFormat": "Non-Heap — {{id}}",
          "refId": "A"
        }
      ],
      "title": "JVM Non-Heap Memory (Metaspace, CodeHeap)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 7,
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"profilezee-auth-service\"}",
          "legendFormat": "Live Threads",
          "refId": "A"
        },
        {
          "expr": "jvm_threads_daemon_threads{job=\"profilezee-auth-service\"}",
          "legendFormat": "Daemon Threads",
          "refId": "B"
        },
        {
          "expr": "jvm_threads_peak_threads{job=\"profilezee-auth-service\"}",
          "legendFormat": "Peak Threads",
          "refId": "C"
        }
      ],
      "title": "JVM Threads",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 8,
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{job=\"profilezee-auth-service\"}[5m])",
          "legendFormat": "GC Pause — {{action}} {{cause}}",
          "refId": "A"
        }
      ],
      "title": "JVM GC Pause Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 102,
      "title": "🗄️ Database — HikariCP Connection Pool",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 35 },
      "id": 9,
      "targets": [
        {
          "expr": "hikaricp_connections_active{job=\"profilezee-auth-service\"}",
          "legendFormat": "Active Connections",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_idle{job=\"profilezee-auth-service\"}",
          "legendFormat": "Idle Connections",
          "refId": "B"
        },
        {
          "expr": "hikaricp_connections_pending{job=\"profilezee-auth-service\"}",
          "legendFormat": "Pending Connections",
          "refId": "C"
        },
        {
          "expr": "hikaricp_connections_max{job=\"profilezee-auth-service\"}",
          "legendFormat": "Max Pool Size",
          "refId": "D"
        }
      ],
      "title": "HikariCP Connection Pool (MySQL — Auth Service)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "s"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 35 },
      "id": 10,
      "targets": [
        {
          "expr": "rate(hikaricp_connections_acquire_seconds_sum{job=\"profilezee-auth-service\"}[5m]) / rate(hikaricp_connections_acquire_seconds_count{job=\"profilezee-auth-service\"}[5m])",
          "legendFormat": "Avg Acquire Time",
          "refId": "A"
        },
        {
          "expr": "hikaricp_connections_acquire_seconds_max{job=\"profilezee-auth-service\"}",
          "legendFormat": "Max Acquire Time",
          "refId": "B"
        }
      ],
      "title": "HikariCP Connection Acquire Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 43 },
      "id": 103,
      "title": "📋 Live Logs per Service",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 44 },
      "id": 11,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"profilezee\", app=\"user-service\"} |= ``",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "User Service Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 44 },
      "id": 12,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"profilezee\", app=\"profile-service\"} |= ``",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Profile Service Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 52 },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"profilezee\", app=\"auth-service\"} |= ``",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Auth Service Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 52 },
      "id": 14,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"profilezee\", app=\"notification-service\"} |= ``",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "Notification Service Logs",
      "type": "logs"
    },
    {
      "datasource": { "type": "loki", "uid": "${loki_datasource}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 60 },
      "id": 15,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "expr": "{namespace=\"profilezee\"} |~ `(?i)error|exception|fatal|traceback`",
          "legendFormat": "",
          "refId": "A"
        }
      ],
      "title": "🔴 All Errors Across ProfileZee",
      "type": "logs"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 68 },
      "id": 104,
      "title": "📈 Service Health Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 69 },
      "id": 16,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "up{job=\"profilezee-user-service\"}",
          "legendFormat": "User Service",
          "refId": "A"
        }
      ],
      "title": "User Service",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 69 },
      "id": 17,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "up{job=\"profilezee-profile-service\"}",
          "legendFormat": "Profile Service",
          "refId": "A"
        }
      ],
      "title": "Profile Service",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 69 },
      "id": 18,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "up{job=\"profilezee-auth-service\"}",
          "legendFormat": "Auth Service",
          "refId": "A"
        }
      ],
      "title": "Auth Service",
      "type": "stat"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "options": { "0": { "text": "DOWN" }, "1": { "text": "UP" } }, "type": "value" }
          ]
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 69 },
      "id": 19,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "expr": "up{job=\"profilezee-notification-service\"}",
          "legendFormat": "Notification Service",
          "refId": "A"
        }
      ],
      "title": "Notification Service",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["profilezee", "microservices", "kubernetes"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource",
        "label": "Prometheus"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "name": "loki_datasource",
        "options": [],
        "query": "loki",
        "refresh": 1,
        "type": "datasource",
        "label": "Loki"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "ProfileZee — Microservices Dashboard",
  "uid": "profilezee-main",
